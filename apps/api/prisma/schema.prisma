// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
   provider     = "prisma-client"
   output       = "../generated/prisma"
   moduleFormat = "cjs"
}

datasource db {
   provider = "postgresql"
}

model User {
   id        String    @id @default(uuid())
   email     String?   @unique
   name      String?
   username  String    @unique
   password  String
   deletedAt DateTime?

   participants RoomParticipant[] @relation("UserParticipants")

   messages Message[] @relation("MessageSender")
}

model Room {
   id          String  @id @default(uuid())
   name        String
   description String?

   participants RoomParticipant[] @relation("RoomParticipants")

   chat Chat? @relation("RoomChat")
}

model RoomParticipant {
   id      String  @id @default(uuid())
   isReady Boolean @default(false)

   @@unique([roomId, userId])
   @@index([roomId])
   @@index([userId])

   userId String
   user   User   @relation("UserParticipants", fields: [userId], references: [id])

   roomId String
   room   Room   @relation("RoomParticipants", fields: [roomId], references: [id], onDelete: Cascade)
}

model Chat {
   id String @id @default(uuid())

   //todo: make required
   roomId String? @unique
   room   Room?   @relation("RoomChat", fields: [roomId], references: [id], onDelete: Cascade)

   messages Message[] @relation("ChatMessages")
}

model Message {
   id      String @id @default(uuid())
   content String

   chatId String
   chat   Chat   @relation("ChatMessages", fields: [chatId], references: [id], onDelete: Cascade)

   senderId String
   sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
   //todo: add createdAt
}
